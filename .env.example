# ---- Server ----
# MySQL connection (Prisma). Use crore-unit Decimal money throughout.
DATABASE_URL="mysql://root:password@localhost:3306/auction"

# HTTP server
PORT=4000
# Comma-separated list of allowed client origins (CORS + Socket.io)
CLIENT_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
# Appended to passwords before hashing/verifying.
PEPPER="change-me-too"

# Uploads (relative to server cwd)
UPLOAD_DIR="../uploads"

# Seed (Phase 1)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"

# ---- Client (Vite, must be prefixed VITE_) ----
VITE_API_URL="http://localhost:4000"
VITE_SOCKET_URL="http://localhost:4000"
